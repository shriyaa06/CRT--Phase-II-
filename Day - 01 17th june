//Maximum Subarray(Leetcode 53)


//BRUTEFORCE TECHNIQUE

class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int maxSum=INT_MIN;
        for(int i=0;i<nums.size();i++){
            int sum=0;
            for(int j=i;j<nums.size();j++){
                sum= sum +nums[j];
                maxSum= max (sum, maxSum);
            }
        }
        return maxSum;
    }
};

//OPTIMIZED TECHNIQUE

class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int maxSum=INT_MIN;
        int sum=0;
        for(int i=0;i<nums.size();i++){
                sum= sum +nums[i];

                if(sum>maxSum){
                    maxSum=sum;
                }
                if(sum<0){
                    sum=0;
                }
            }
        return maxSum;
    }
};


//Program 3
//Sort colours(Leetcode 75)


//BRUTEFORCE TECHNIQUE

class Solution {
public:
    void sortColors(vector<int>& nums) {
        int count0=0;
        int count1=0;
        int count2=0;

        for(int i=0;i<nums.size();i++){
            if(nums[i]==0){
                count0 ++;
            }else if(nums[i]==1){
                count1 ++;
            }else{
                count2 ++;
            }
        }
        for(int i=0;i<nums.size();i++){
            if(i<count0){
                nums[i]=0;
            }else if(i<count0+count1){
                nums[i]=1;
            }else{
                nums[i]=2;
            }
        }
    }

};

//OPTIMIZED TECHNIQUE

class Solution {
public:
    void sortColors(vector<int>& nums) {
        int start=0;
        int mid=0;
        int end=nums.size()-1;

        while(mid<=end){
            if(nums[mid]==0){
                swap(nums[start],nums[mid]);
                start++;
                mid++;
            }else if(nums[mid]==1){
                mid++;
            }else{
                swap(nums[mid],nums[end]);
                end--;
            }
        }
    }
};
